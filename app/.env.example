# ─────────────────────────────────────────────
#  Frontend Environment Variables
# ─────────────────────────────────────────────
#  Dev:  Use your local IP address (e.g., http://192.168.1.50:3000)
#  Prod: Use your Render backend URL (e.g., https://your-app.onrender.com)
#
#  For production builds, create a .env.production file with
#  the production URLs. EAS Build will pick it up automatically.
# ─────────────────────────────────────────────

EXPO_PUBLIC_API_URL=http://192.168.1.50:3000/api
EXPO_PUBLIC_SERVER_URL=http://192.168.1.50:3000
