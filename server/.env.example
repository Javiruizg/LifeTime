# Server
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5433/tfg_db"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET=dev-secret-change-in-production
JWT_SECRET_REFRESH=dev-refresh-secret-change-in-production
JWT_EXPIRATION=15m
REFRESH_TOKEN_EXPIRATION=7d

# Uploads
STORAGE_PROVIDER=local
UPLOADS_DIR=uploads
